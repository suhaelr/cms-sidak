# Server
PORT=3000
CORS_ORIGIN=http://localhost:8080

# Database
DATABASE_URL=postgres://postgres:admin@localhost:5432/sidak

# Auth
JWT_SECRET=dev-jwt-secret-change-me
JWT_ISSUER=sidak-api
AUTH_MODE=local

# S3 / MinIO (defaults)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/uploads

# Cloudflare Turnstile — secret key for server-side verification
# Dev test secret (pairs with site key 1x00000000000000000000AA): 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# BGN SIPGN API gateway (defaults)
GATEWAY_URL=https://gateway-sipgn.bgn.go.id

# Ory SSO — optional, hanya diperlukan jika AUTH_MODE=ory atau both
# ORY_AUTHORIZATION_ENDPOINT=http://localhost:4444/oauth2/auth
# ORY_OIDC_CLIENT_ID=
# ORY_OIDC_CLIENT_SECRET=
ORY_OIDC_REDIRECT_URI=http://localhost:8080/admin/login/callback

# Feature flags — Unleash-compatible API
# FEATURE_FLAGS_ENABLED=true
# UNLEASH_URL=
# UNLEASH_INSTANCE_ID=
# UNLEASH_API_TOKEN=
# UNLEASH_APP_NAME=production
# FEATURE_FLAGS_REFRESH_SECONDS=30
